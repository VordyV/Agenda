<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="450"
             xmlns:vm="clr-namespace:Agenda.Modules.TCPCModule"
             x:Class="Agenda.Modules.TCPCModule.TcpcView">
    
    <Border Padding="10 7">
        <Grid RowDefinitions="*, Auto" ColumnDefinitions="*, Auto" RowSpacing="7" ColumnSpacing="7">
            <ListBox Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Name="TextBoxOutput"/>
            <TextBox Grid.Row="1" Grid.Column="0" Name="TextBoxInput"/>
            <Button Grid.Row="1" Grid.Column="1" Name="ButtonSend" Content="Send" Click="ButtonSend_OnClick"/>
        </Grid>   
    </Border>
</UserControl>
